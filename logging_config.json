{
    "version": 1,
    "disable_existing_loggers": false,
    "formatters": {
        "detailed": {
            "format": "%(asctime)s | %(levelname)s | %(name)s | %(message)s"
        }
    },
    "handlers": {
        "app_file": {
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "logs/app.log",
            "maxBytes": 5000000,
            "backupCount": 5,
            "encoding": "utf-8",
            "formatter": "detailed"
        },
        "http_file": {
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "logs/http.log",
            "maxBytes": 5000000,
            "backupCount": 5,
            "encoding": "utf-8",
            "formatter": "detailed"
        },
        "flet_file": {
            "class": "logging.handlers.RotatingFileHandler",
            "filename": "logs/flet.log",
            "maxBytes": 5000000,
            "backupCount": 5,
            "encoding": "utf-8",
            "formatter": "detailed"
        },
        "console": {
            "class": "logging.StreamHandler",
            "formatter": "detailed"
        }
    },
    "loggers": {
        "app": {
            "level": "INFO",
            "handlers": [
                "app_file",
                "console"
            ],
            "propagate": false
        },
        "app.api": {
            "level": "INFO",
            "handlers": [
                "app_file"
            ],
            "propagate": false
        },
        "app.auth": {
            "level": "INFO",
            "handlers": [
                "app_file"
            ],
            "propagate": false
        },
        "app.ws": {
            "level": "INFO",
            "handlers": [
                "app_file"
            ],
            "propagate": false
        },
        "app.epub": {
            "level": "INFO",
            "handlers": [
                "app_file"
            ],
            "propagate": false
        },
        "httpx": {
            "level": "WARNING",
            "handlers": [
                "http_file"
            ],
            "propagate": false
        },
        "flet": {
            "level": "WARNING",
            "handlers": [
                "flet_file"
            ],
            "propagate": false
        },
        "httpcore": {
            "level": "WARNING",
            "handlers": [
                "http_file"
            ],
            "propagate": false
        }
    },
    "root": {
        "level": "WARNING",
        "handlers": [
            "console"
        ]
    }
}
